<Window x:Class="GymTracker.Views.ClientesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GymTracker — Panel de Clientes"
        Height="620" Width="860"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <DockPanel>

        <!-- MENU -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Archivo">
                <MenuItem Header="Cerrar sesión" Command="{Binding CerrarSesionCommand}"/>
                <Separator/>
                <MenuItem Header="Salir" Command="{Binding SalirCommand}"/>
            </MenuItem>
            <MenuItem Header="_Ayuda">
                <MenuItem Header="Acerca de GymTracker" Command="{Binding AcercaDeCommand}"/>
            </MenuItem>
        </Menu>

        <!-- HEADER BAR -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="18,10">
            <DockPanel>
                <TextBlock Text="GymTracker" FontSize="20" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding NombreEntrenador, StringFormat='Entrenador: {0}'}"
                           FontSize="13" Foreground="#BBDEFB"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom" Background="#E8EAF6">
            <StatusBarItem>
                <TextBlock Text="Listo" Foreground="#3949AB" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding FechaActual}" Foreground="#3949AB" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- MAIN CONTENT -->
        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Client selection card -->
            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#BDBDBD" ShadowDepth="1" BlurRadius="8" Opacity="0.25"/>
                </Border.Effect>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Borrar Cliente"
                            Command="{Binding EliminarClienteCommand}"
                            Height="34" Padding="14,0" Margin="8,0,0,0"
                            Background="#C62828" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="13"/>
                    <Button DockPanel.Dock="Right" Content="+ Añadir Cliente"
                            Command="{Binding AgregarClienteCommand}"
                            Height="34" Padding="14,0" Margin="8,0,0,0"
                            Background="#2E7D32" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontSize="13"/>
                    <TextBlock DockPanel.Dock="Left" Text="Cliente:"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="#424242" Margin="0,0,12,0"/>
                    <ComboBox ItemsSource="{Binding Clientes}"
                              SelectedItem="{Binding ClienteSeleccionado}"
                              DisplayMemberPath="Nombre"
                              Height="34" FontSize="14" Padding="8,0"
                              MaxWidth="320" HorizontalAlignment="Left"/>
                </DockPanel>
            </Border>

            <!-- Exercises card -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="#BDBDBD" ShadowDepth="1" BlurRadius="8" Opacity="0.25"/>
                </Border.Effect>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Ejercicios" FontSize="15" FontWeight="Bold" Foreground="#1565C0"/>
                        <TextBlock Text="  —  Doble clic para ver los registros"
                                   FontSize="12" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DataGrid x:Name="DataGridEjercicios"
                              ItemsSource="{Binding Ejercicios}"
                              SelectedItem="{Binding EjercicioSeleccionado}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeight="38"
                              FontSize="13"
                              HeadersVisibility="Column"
                              MouseDoubleClick="DataGridEjercicios_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombre del Ejercicio"
                                               Binding="{Binding Nombre}" Width="*"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
