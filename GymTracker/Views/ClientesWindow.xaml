<Window x:Class="GymTracker.Views.ClientesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GymTracker.Converters"
        Title="GymTracker — Panel de Clientes"
        Height="620" Width="860"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ByteArrayToImageConverter x:Key="ByteToImage"/>
    </Window.Resources>

    <DockPanel>

        <!-- MENU -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Archivo">
                <MenuItem Header="Cerrar sesión" Command="{Binding CerrarSesionCommand}"/>
                <Separator/>
                <MenuItem Header="Salir" Command="{Binding SalirCommand}"/>
            </MenuItem>
            <MenuItem Header="_Rutinas">
                <MenuItem Header="Gestionar Rutinas" Command="{Binding GestionarRutinasCommand}"/>
            </MenuItem>
            <MenuItem Header="_Ejercicios">
                <MenuItem Header="Gestionar Ejercicios" Command="{Binding GestionarEjerciciosCommand}"/>
            </MenuItem>
            <MenuItem Header="_Ayuda">
                <MenuItem Header="Acerca de GymTracker" Command="{Binding AcercaDeCommand}"/>
            </MenuItem>
        </Menu>

        <!-- HEADER BAR -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="18,10">
            <DockPanel>
                <TextBlock Text="GymTracker" FontSize="20" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding NombreEntrenador, StringFormat='Entrenador: {0}'}"
                           FontSize="13" Foreground="#BBDEFB"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom" Background="#E8EAF6">
            <StatusBarItem>
                <TextBlock Text="Listo" Foreground="#3949AB" FontSize="12"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding FechaActual}" Foreground="#3949AB" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- MAIN CONTENT -->
        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Client selection card -->
            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#BDBDBD" ShadowDepth="1" BlurRadius="8" Opacity="0.25"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Row 1: client selector -->
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Borrar Cliente"
                                Command="{Binding EliminarClienteCommand}"
                                Height="34" Padding="14,0" Margin="8,0,0,0"
                                Background="#C62828" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"/>
                        <Button DockPanel.Dock="Right" Content="+ Añadir Cliente"
                                Command="{Binding AgregarClienteCommand}"
                                Height="34" Padding="14,0" Margin="8,0,0,0"
                                Background="#2E7D32" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="13"/>
                        <TextBlock DockPanel.Dock="Left" Text="Cliente:"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Foreground="#424242" Margin="0,0,12,0"/>
                        <ComboBox ItemsSource="{Binding Clientes}"
                                  SelectedItem="{Binding ClienteSeleccionado}"
                                  DisplayMemberPath="Nombre"
                                  Height="34" FontSize="14" Padding="8,0"
                                  MaxWidth="320" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <!-- Row 2: routine assignment -->
                    <DockPanel Margin="0,10,0,0">
                        <Button DockPanel.Dock="Right" Content="Quitar Rutina"
                                Command="{Binding QuitarRutinaCommand}"
                                Height="30" Padding="10,0" Margin="8,0,0,0"
                                Background="#546E7A" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                        <Button DockPanel.Dock="Right" Content="Asignar"
                                Command="{Binding AsignarRutinaCommand}"
                                Height="30" Padding="10,0" Margin="8,0,0,0"
                                Background="#1565C0" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                        <TextBlock DockPanel.Dock="Left" Text="Rutina actual:"
                                   FontSize="13" VerticalAlignment="Center"
                                   Foreground="#616161" Margin="0,0,12,0"/>
                        <ComboBox ItemsSource="{Binding Rutinas}"
                                  SelectedItem="{Binding RutinaSeleccionadaCliente}"
                                  DisplayMemberPath="Nombre"
                                  Height="30" FontSize="13" Padding="8,0"
                                  MaxWidth="280" HorizontalAlignment="Left"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Exercises card -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="#BDBDBD" ShadowDepth="1" BlurRadius="8" Opacity="0.25"/>
                </Border.Effect>
                <DockPanel>
                    <!-- Header -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Ejercicios de la rutina" FontSize="15" FontWeight="Bold"
                                   Foreground="#1565C0"/>
                        <TextBlock Text="  —  Doble clic para registrar peso"
                                   FontSize="12" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Empty state: no routine assigned -->
                    <Border DockPanel.Dock="Top"
                            Visibility="{Binding SinRutina, Converter={StaticResource BoolToVis}}"
                            Background="#F5F5F5" CornerRadius="6" Padding="20,30"
                            HorizontalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Sin rutina asignada" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                            <TextBlock Text="Selecciona una rutina en el desplegable de arriba y pulsa Asignar."
                                       FontSize="12" Foreground="#BDBDBD" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid with routine exercises -->
                    <DataGrid x:Name="DataGridEjercicios"
                              ItemsSource="{Binding EjerciciosRutina}"
                              SelectedItem="{Binding EjercicioSeleccionado}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeight="40"
                              FontSize="13"
                              HeadersVisibility="Column"
                              MouseDoubleClick="DataGridEjercicios_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="48">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="34" Height="34" CornerRadius="4"
                                                Background="#ECEFF1" Margin="2">
                                            <Image Source="{Binding Foto, Converter={StaticResource ByteToImage}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Ejercicio"
                                               Binding="{Binding NombreEjercicio}" Width="*"/>
                            <DataGridTextColumn Header="Series"
                                               Binding="{Binding Series}" Width="80"/>
                            <DataGridTextColumn Header="Reps objetivo"
                                               Binding="{Binding RepsObjetivo}" Width="110"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
