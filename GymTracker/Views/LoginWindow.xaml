<Window x:Class="GymTracker.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GymTracker" Height="430" Width="440"
        MinHeight="380" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#ECEFF1">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="BtnLogin" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="White" CornerRadius="10"
                Width="360" MaxHeight="420"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#9E9E9E" ShadowDepth="2" BlurRadius="16" Opacity="0.35"/>
            </Border.Effect>

            <StackPanel Margin="45,35">

                <!-- Header -->
                <TextBlock Text="GymTracker" FontSize="32" FontWeight="Bold"
                           Foreground="#1565C0" HorizontalAlignment="Center"/>
                <TextBlock Text="Panel de Entrenadores" FontSize="13" Foreground="#78909C"
                           HorizontalAlignment="Center" Margin="0,4,0,32"/>

                <!-- Entrenador -->
                <TextBlock Text="ENTRENADOR" FontSize="11" Foreground="#607D8B"
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Entrenadores}"
                          SelectedItem="{Binding EntrenadorSeleccionado}"
                          DisplayMemberPath="Nombre"
                          Height="40" FontSize="14"
                          Padding="8,0" BorderBrush="#B0BEC5"
                          Margin="0,0,0,18"/>

                <!-- PIN -->
                <TextBlock Text="PIN" FontSize="11" Foreground="#607D8B"
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PinBox"
                             Height="40" FontSize="18"
                             Padding="8,0" BorderBrush="#B0BEC5"
                             KeyDown="PinBox_KeyDown"
                             Margin="0,0,0,6"/>

                <!-- Error -->
                <TextBlock Text="{Binding MensajeError}" Foreground="#E53935"
                           FontSize="12" Margin="0,0,0,10"
                           Visibility="{Binding HayError, Converter={StaticResource BoolToVis}}"/>

                <!-- Botón -->
                <Button Content="Iniciar Sesión" Style="{StaticResource BtnLogin}"
                        Click="BtnLogin_Click" Margin="0,6,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
