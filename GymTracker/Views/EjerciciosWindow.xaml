<Window x:Class="GymTracker.Views.EjerciciosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GymTracker.Converters"
        Title="GymTracker — Gestión de Ejercicios"
        Height="580" Width="760"
        MinHeight="450" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F5">

    <Window.Resources>
        <conv:ByteArrayToImageConverter x:Key="ByteToImage"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>

        <!-- HEADER BAR -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="18,10">
            <TextBlock Text="Gestión de Ejercicios" FontSize="18" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center"/>
        </Border>

        <!-- BOTTOM BUTTONS -->
        <Border DockPanel.Dock="Bottom" Background="White" Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Cerrar"
                        Click="BtnCerrar_Click"
                        Height="34" Padding="20,0"
                        Background="#546E7A" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13"/>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Margin="16,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="290"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: exercise list -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12">
                <Border.Effect>
                    <DropShadowEffect Color="#BDBDBD" ShadowDepth="1" BlurRadius="8" Opacity="0.25"/>
                </Border.Effect>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Ejercicios" FontSize="15" FontWeight="Bold"
                                   Foreground="#1565C0" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="+ Nuevo"
                                Command="{Binding NuevoCommand}"
                                Height="30" Padding="12,0"
                                Background="#2E7D32" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Ejercicios}"
                             SelectedItem="{Binding EjercicioSeleccionado}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="6,6"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="44" Height="44" CornerRadius="4"
                                            Background="#ECEFF1" Margin="0,0,10,0">
                                        <Image Source="{Binding Foto, Converter={StaticResource ByteToImage}}"
                                               Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <TextBlock Text="{Binding Nombre}"
                                               FontSize="13" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- RIGHT: form -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="18">
                <Border.Effect>
                    <DropShadowEffect Color="#BDBDBD" ShadowDepth="1" BlurRadius="8" Opacity="0.25"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding TituloFormulario}" FontSize="15" FontWeight="Bold"
                               Foreground="#1565C0" Margin="0,0,0,16"/>

                    <!-- Image preview -->
                    <Border Width="220" Height="160" CornerRadius="6"
                            Background="#ECEFF1" Margin="0,0,0,10"
                            HorizontalAlignment="Center">
                        <Grid>
                            <!-- Placeholder when no image -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🏋️" FontSize="40"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Sin imagen" FontSize="11"
                                           Foreground="#9E9E9E" HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Actual image -->
                            <Image Source="{Binding FotoPreview, Converter={StaticResource ByteToImage}}"
                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                                   MaxHeight="160"/>
                        </Grid>
                    </Border>

                    <!-- Image buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Button Content="Elegir imagen"
                                Command="{Binding ElegirImagenCommand}"
                                Height="28" Padding="10,0" Margin="0,0,8,0"
                                Background="#1565C0" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                        <Button Content="Quitar"
                                Command="{Binding QuitarImagenCommand}"
                                Height="28" Padding="10,0"
                                Background="#546E7A" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                    </StackPanel>

                    <!-- Name field -->
                    <TextBlock Text="NOMBRE" FontSize="11" FontWeight="SemiBold"
                               Foreground="#607D8B" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NombreInput, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" FontSize="14" Padding="8,0"
                             BorderBrush="#B0BEC5" Margin="0,0,0,18"/>

                    <!-- Save button -->
                    <Button Content="Guardar"
                            Command="{Binding GuardarCommand}"
                            Height="38" FontSize="13" FontWeight="SemiBold"
                            Background="#1565C0" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,0,8"/>

                    <!-- Delete button (only when editing) -->
                    <Button Content="Eliminar ejercicio"
                            Command="{Binding EliminarCommand}"
                            Height="36" FontSize="13"
                            Background="#C62828" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Visibility="{Binding EsEdicion, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
