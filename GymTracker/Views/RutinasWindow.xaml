<Window x:Class="GymTracker.Views.RutinasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GymTracker — Gestión de Rutinas"
        Height="620" Width="960"
        MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>

        <!-- MENU -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Archivo">
                <MenuItem Header="Cerrar" Click="BtnCerrar_Click"/>
            </MenuItem>
        </Menu>

        <!-- HEADER -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="18,10">
            <TextBlock Text="Gestión de Rutinas" FontSize="20" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom" Background="#E8EAF6">
            <StatusBarItem>
                <TextBlock Text="{Binding Rutinas.Count, StringFormat='Rutinas disponibles: {0}'}"
                           Foreground="#3949AB" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- MAIN: two panels -->
        <Grid Margin="20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: routine list -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="14">
                <Border.Effect>
                    <DropShadowEffect Color="#BDBDBD" ShadowDepth="1" BlurRadius="8" Opacity="0.25"/>
                </Border.Effect>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Rutinas" FontSize="15" FontWeight="Bold"
                               Foreground="#1565C0" Margin="0,0,0,12"/>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                HorizontalAlignment="Stretch" Margin="0,10,0,0">
                        <Button Content="+ Nueva" Command="{Binding NuevaRutinaCommand}"
                                Height="32" Padding="12,0" Margin="0,0,8,0"
                                Background="#2E7D32" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                        <Button Content="Eliminar" Command="{Binding EliminarRutinaCommand}"
                                Height="32" Padding="12,0"
                                Background="#C62828" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Rutinas}"
                             SelectedItem="{Binding RutinaSeleccionada}"
                             DisplayMemberPath="Nombre"
                             BorderThickness="1" BorderBrush="#E0E0E0"
                             FontSize="13"/>
                </DockPanel>
            </Border>

            <!-- RIGHT: routine exercises -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="#BDBDBD" ShadowDepth="1" BlurRadius="8" Opacity="0.25"/>
                </Border.Effect>
                <DockPanel>

                    <!-- Header -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Ejercicios de: " FontSize="15" FontWeight="Bold"
                                   Foreground="#1565C0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding RutinaSeleccionada.Nombre, FallbackValue='(selecciona una rutina)'}"
                                   FontSize="15" FontWeight="Bold" Foreground="#424242"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Add exercise form -->
                    <Border DockPanel.Dock="Bottom" Background="#F5F5F5" CornerRadius="6"
                            Padding="12,10" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding EjerciciosDisponibles}"
                                      SelectedItem="{Binding EjercicioParaAgregar}"
                                      DisplayMemberPath="Nombre"
                                      Height="34" FontSize="13" Padding="8,0" Margin="0,0,8,0"/>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Series" FontSize="10" Foreground="#9E9E9E" Margin="0,0,0,2"/>
                                <TextBox Text="{Binding SeriesInput, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" FontSize="13" Padding="6,0" BorderBrush="#B0BEC5"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Reps" FontSize="10" Foreground="#9E9E9E" Margin="0,0,0,2"/>
                                <TextBox Text="{Binding RepsInput, UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" FontSize="13" Padding="6,0" BorderBrush="#B0BEC5"/>
                            </StackPanel>

                            <Button Grid.Column="3" Content="+ Añadir"
                                    Command="{Binding AgregarEjercicioCommand}"
                                    Height="34" Padding="14,0" Margin="0,18,8,0"
                                    Background="#1565C0" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12"/>

                            <Button Grid.Column="4" Content="Quitar"
                                    Command="{Binding QuitarEjercicioCommand}"
                                    Height="34" Padding="14,0" Margin="0,18,0,0"
                                    Background="#C62828" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Error -->
                    <TextBlock DockPanel.Dock="Bottom"
                               Text="{Binding MensajeError}" Foreground="#E53935"
                               FontSize="11" Margin="0,4,0,0"
                               Visibility="{Binding HayError, Converter={StaticResource BoolToVis}}"/>

                    <!-- DataGrid -->
                    <DataGrid ItemsSource="{Binding EjerciciosRutina}"
                              SelectedItem="{Binding EjercicioRutinaSeleccionado}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeight="38"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ejercicio"
                                               Binding="{Binding NombreEjercicio}" Width="*"/>
                            <DataGridTextColumn Header="Series"
                                               Binding="{Binding Series}" Width="80"/>
                            <DataGridTextColumn Header="Reps objetivo"
                                               Binding="{Binding RepsObjetivo}" Width="110"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
