<Window x:Class="GymTracker.Views.NombreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Añadir Cliente" Height="175" Width="370"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <StackPanel Margin="24,20">
        <TextBlock Text="Nombre del cliente:" FontSize="13" Foreground="#424242" Margin="0,0,0,8"/>
        <TextBox x:Name="TxtNombre" Height="36" FontSize="14" Padding="8,0"
                 BorderBrush="#B0BEC5" KeyDown="TxtNombre_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Width="90" Height="34" Margin="0,0,10,0"
                    Click="BtnCancelar_Click" Background="#EEEEEE" BorderBrush="#BDBDBD"/>
            <Button Content="Aceptar" Width="90" Height="34"
                    Click="BtnAceptar_Click"
                    Background="#1565C0" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>
